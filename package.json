{
  "name": "tiny-inventory",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w tiny-inventory-backend\" \"npm run dev -w tiny-inventory-frontend\"",
    "build": "npm run build -w tiny-inventory-backend && npm run build -w tiny-inventory-frontend",
    "test": "npm run test -w tiny-inventory-backend && npm run test -w tiny-inventory-frontend",
    "test:e2e": "npm run test:e2e -w tiny-inventory-frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:migrate": "npm run db:migrate -w tiny-inventory-backend",
    "db:seed": "npm run db:seed -w tiny-inventory-backend",
    "db:studio": "npm run db:studio -w tiny-inventory-backend",
    "generate:contracts": "npm run db:generate -w tiny-inventory-backend",
    "check:drift": "tsx scripts/check-contract-drift.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.26.0"
  }
}
